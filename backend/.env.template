# Node settings
NODE_ENV=development
PORT=3001

# Relational Database connection (PostgreSQL)
# Matches docker-compose container credentials
DATABASE_URL=postgresql://postgres:postgrespassword@localhost:5432/inboxiq_dev?schema=public

# Caching & Background Queues (Redis)
REDIS_URL=redis://localhost:6379

# Cryptography & Security
# 32-byte secret key (min 32 chars) for encrypting tokens in PostgreSQL (AES-256-GCM)
ENCRYPTION_KEY=encryptionkeyplaceholdertextmustbe32bytes
# Shared JWT key for frontend-to-backend request verification
SHARED_JWT_SECRET=supersecretsharedjwtkeyvalueplaceholder

# Google Cloud OAuth API Credentials (must match your Google Developer Console)
GOOGLE_CLIENT_ID=google_client_id_placeholder
GOOGLE_CLIENT_SECRET=google_client_secret_placeholder
GMAIL_REDIRECT_URI=http://localhost:3001/api/gmail/connect/callback

# Gemini API Key (Required for AI Email Analysis)
GEMINI_API_KEY=gemini_api_key_placeholder

