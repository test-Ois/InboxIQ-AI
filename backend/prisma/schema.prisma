datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                 String              @id @default(uuid()) @db.Uuid
  authProviderId     String              @unique @map("auth_provider_id")
  email              String              @unique
  name               String
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  accounts           ConnectedAccount[]
  emails             Email[]
  auditLogs          AuditLog[]
  tasks              Task[]
  cleanupAnalyses    CleanupAnalysis[]
  copilotSuggestions CopilotSuggestion[]
  calendarEvents     CalendarEvent[]

  @@index([email])
  @@index([authProviderId])
  @@map("users")
}

model ConnectedAccount {
  id                     String   @id @default(uuid()) @db.Uuid
  userId                 String   @map("user_id") @db.Uuid
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider               String   @default("google")
  providerEmail          String   @map("provider_email")
  encryptedAccessToken   String   @map("encrypted_access_token")
  encryptedRefreshToken  String   @map("encrypted_refresh_token")
  tokenExpiry            DateTime @map("token_expiry")
  gmailHistoryId         String?  @map("gmail_history_id")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@unique([userId, providerEmail], name: "unique_user_provider_email")
  @@index([userId])
  @@index([providerEmail])
  @@map("connected_accounts")
}

model Email {
  id                 String              @id @default(uuid()) @db.Uuid
  userId             String              @map("user_id") @db.Uuid
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  gmailMessageId     String              @map("gmail_message_id")
  gmailThreadId      String              @map("gmail_thread_id")
  gmailHistoryId     String?             @map("gmail_history_id")
  sender             String
  subject            String
  snippet            String?
  labels             String[]
  receivedAt         DateTime            @map("received_at")
  syncedAt           DateTime            @default(now()) @map("synced_at")
  createdAt          DateTime            @default(now()) @map("created_at")
  analysis           EmailAnalysis?
  tasks              Task[]
  fraudAnalysis      FraudAnalysis?
  cleanupCategory    CleanupCategory?    @map("cleanup_category")
  cleanupConfidence  Float?              @map("cleanup_confidence")
  copilotSuggestions CopilotSuggestion[]
  calendarEvents     CalendarEvent[]

  @@unique([userId, gmailMessageId], name: "unique_user_gmail_message_id")
  @@index([userId, receivedAt(sort: Desc)])
  @@index([gmailThreadId])
  @@index([userId, cleanupCategory])
  @@map("emails")
}

model EmailAnalysis {
  id              String   @id @default(uuid()) @db.Uuid
  emailId         String   @unique @map("email_id") @db.Uuid
  email           Email    @relation(fields: [emailId], references: [id], onDelete: Cascade)
  category        String
  priority        String
  priorityScore   Int      @map("priority_score")
  actionRequired  Boolean  @map("action_required")
  deadline        DateTime?
  summary         String
  confidenceScore Float    @map("confidence_score")
  modelName       String   @map("model_name")
  promptVersion   String   @map("prompt_version")
  analyzedAt      DateTime @default(now()) @map("analyzed_at")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([priority])
  @@index([category])
  @@index([deadline])
  @@map("email_analyses")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  details   Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([action, createdAt(sort: Desc)])
  @@map("audit_logs")
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum TaskSource {
  EMAIL
  MANUAL
  AI_GENERATED
}

model Task {
  id              String       @id @default(uuid()) @db.Uuid
  userId          String       @map("user_id") @db.Uuid
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailId         String?      @map("email_id") @db.Uuid
  email           Email?       @relation(fields: [emailId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  priority        TaskPriority @default(MEDIUM)
  status          TaskStatus   @default(PENDING)
  dueDate         DateTime?    @map("due_date")
  completedAt     DateTime?    @map("completed_at")
  confidenceScore Float        @default(1.0) @map("confidence_score")
  source          TaskSource   @default(EMAIL)
  extractionModel String?      @map("extraction_model")
  promptVersion   String?      @map("prompt_version")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@index([userId])
  @@index([emailId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@index([userId, status])
  @@index([userId, priority])
  @@map("tasks")
}

enum FraudRiskLevel {
  SAFE
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FraudType {
  NONE
  PHISHING
  SPAM
  SPOOFING
  MALWARE
  BEC
  SCAM
  IMPERSONATION
  OTHER
}

model FraudAnalysis {
  id              String         @id @default(uuid()) @db.Uuid
  emailId         String         @unique @map("email_id") @db.Uuid
  email           Email          @relation(fields: [emailId], references: [id], onDelete: Cascade)
  riskLevel       FraudRiskLevel @map("risk_level")
  fraudType       FraudType      @map("fraud_type")
  confidenceScore Float          @map("confidence_score")
  explanation     String
  indicators      Json
  modelName       String         @map("model_name")
  promptVersion   String         @map("prompt_version")
  analyzedAt      DateTime       @default(now()) @map("analyzed_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  @@index([riskLevel])
  @@index([fraudType])
  @@map("fraud_analyses")
}

enum CleanupCategory {
  IMPORTANT
  PROMOTIONAL
  NEWSLETTER
  SOCIAL
  UPDATES
  CLUTTER
}

model CleanupAnalysis {
  id                         String          @id @default(uuid()) @db.Uuid
  userId                     String          @map("user_id") @db.Uuid
  user                       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  inboxHealthScore           Int             @map("inbox_health_score")
  previousHealthScore        Int?            @map("previous_health_score")
  promotionalCount           Int             @map("promotional_count")
  newsletterCount            Int             @map("newsletter_count")
  socialCount                Int             @map("social_count")
  updatesCount               Int             @map("updates_count")
  clutterCount               Int             @map("clutter_count")
  estimatedStorageRecoveryMB Float           @map("estimated_storage_recovery_mb")
  recommendations            Json
  analyzedAt                 DateTime        @default(now()) @map("analyzed_at")
  createdAt                  DateTime        @default(now()) @map("created_at")
  updatedAt                  DateTime        @updatedAt @map("updated_at")

  @@index([userId])
  @@index([analyzedAt])
  @@map("cleanup_analyses")
}

enum CopilotSuggestionType {
  REPLY
  REWRITE
  FOLLOWUP
  MEETING
  SUMMARY
  CUSTOM
}

enum CopilotTone {
  PROFESSIONAL
  CASUAL
  APOLOGETIC
  DIRECT
  ENTHUSIASTIC
}

model CopilotSuggestion {
  id               String                @id @default(uuid()) @db.Uuid
  userId           String                @map("user_id") @db.Uuid
  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailId          String?               @map("email_id") @db.Uuid
  email            Email?                @relation(fields: [emailId], references: [id], onDelete: SetNull)
  suggestionType   CopilotSuggestionType @map("suggestion_type")
  tone             CopilotTone?          @map("tone")
  inputContext     Json                  @map("input_context")
  generatedText    String                @map("generated_text")
  modelName        String                @map("model_name")
  promptVersion    String                @map("prompt_version")
  generatedTokens  Int?                  @map("generated_tokens")
  estimatedCost    Float?                @map("estimated_cost")
  generationTimeMs Int?                  @map("generation_time_ms")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")

  @@index([userId])
  @@index([emailId])
  @@index([suggestionType])
  @@index([createdAt])
  @@map("copilot_suggestions")
}

enum MeetingType {
  STATUS_UPDATE
  INTERVIEW
  PROJECT_DISCUSSION
  CLIENT_MEETING
  FOLLOW_UP
  OTHER
}

enum MeetingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  TENTATIVE
  COMPLETED
}

model CalendarEvent {
  id            String        @id @default(uuid()) @db.Uuid
  userId        String        @map("user_id") @db.Uuid
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailId       String?       @map("email_id") @db.Uuid
  email         Email?        @relation(fields: [emailId], references: [id], onDelete: Cascade)
  googleEventId String?       @map("google_event_id")
  title         String
  description   String?
  location      String?
  meetingUrl    String?       @map("meeting_url")
  timezone      String        @default("UTC")
  startTime     DateTime      @map("start_time")
  endTime       DateTime      @map("end_time")
  meetingType   MeetingType   @map("meeting_type")
  status        MeetingStatus @default(PENDING)
  attendees     Json?
  isConflict    Boolean       @default(false) @map("is_conflict")
  isSynced      Boolean       @default(false) @map("is_synced")
  metadata      Json?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@index([userId])
  @@index([startTime])
  @@index([meetingType])
  @@index([googleEventId])
  @@map("calendar_events")
}


