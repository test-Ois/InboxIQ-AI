# NextAuth Configuration
# Run `npx auth secret` or generate a random 32-character string
AUTH_SECRET=authsecretplaceholdertextmustbe32bytes
NEXTAUTH_URL=http://localhost:3000

# NestJS Backend Connection
BACKEND_URL=http://localhost:3001

# Shared Backend Auth JWT Secret (Must match backend SHARED_JWT_SECRET)
SHARED_JWT_SECRET=supersecretsharedjwtkeyvalueplaceholder

# Google OAuth Credentials (Required for NextAuth Google login)
# Retrieve from Google Cloud Console
GOOGLE_CLIENT_ID=google_client_id_placeholder
GOOGLE_CLIENT_SECRET=google_client_secret_placeholder
